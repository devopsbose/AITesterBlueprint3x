{
  "name": "ai-tester-blueprint-pom",
  "version": "1.0.0",
  "description": "TypeScript Playwright POM Framework with UI, API, and Mobile Testing support",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "test:ui": "playwright test src/tests/ui/**/*.ts",
    "test:api": "playwright test src/tests/api/**/*.ts",
    "test:mobile": "playwright test src/tests/mobile/**/*.ts",
    "test:all": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "mcp": "node dist/mcp/server.js"
  },
  "keywords": ["playwright", "typescript", "pom", "testing", "automation", "api", "mobile"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.4.0"
  }
}
